{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build && pip install -r backend_python/requirements.txt"
  },
  "deploy": {
    "startCommand": "cd backend_python && python -m uvicorn main:app --host 0.0.0.0 --port ${PORT:-8001}",
    "restartPolicyType": "ON_FAILURE"
  }
}
